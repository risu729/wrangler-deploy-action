#!/usr/bin/env bash

set -euo pipefail

if [[ -n ${FAKE_MISE_LOG:-} ]]; then
	printf '%s :: %s\n' "${PWD}" "$*" >>"${FAKE_MISE_LOG}"
fi

if [[ $# -eq 2 && $1 == "which" && $2 == "wrangler" ]]; then
	if [[ ${FAKE_WRANGLER_MISSING:-} == "1" ]]; then
		exit 1
	fi
	printf '%s\n' "${BASH_SOURCE[0]%/*}/wrangler"
	exit 0
fi

if [[ $# -lt 4 || $1 != "exec" || $2 != "--" || $3 != "wrangler" ]]; then
	echo "Unexpected mise invocation: $*" >&2
	exit 1
fi
shift 3
"${BASH_SOURCE[0]%/*}/wrangler" "$@"
