#!/usr/bin/env bash

set -euo pipefail

if [[ $# -lt 4 || $1 != "exec" || $2 != "--" || $3 != "wrangler" ]]; then
	echo "Unexpected mise invocation: $*" >&2
	exit 1
fi
shift 3

output_path="${WRANGLER_OUTPUT_FILE_PATH:?}"
mkdir -p "$(dirname "${output_path}")"

if [[ ${FAKE_WRANGLER_OUTPUT:-} == "missing" ]]; then
	exit 0
fi

case "$1 $2" in
"versions upload")
	if [[ " ${*} " != *" --preview-alias pr-42 "* ]]; then
		echo "Preview alias was not forwarded: $*" >&2
		exit 1
	fi
	printf '%s\n' \
		'{"version":1,"type":"version-upload","preview_url":"https://version-worker.example.workers.dev","preview_alias_url":"https://pr-42-worker.example.workers.dev"}' \
		>"${output_path}"
	;;
"deploy --config")
	if [[ " ${*} " == *" --dry-run "* ]]; then
		exit 0
	fi
	printf '%s\n' \
		'{"version":1,"type":"deploy","targets":["https://one.example.com","https://two.example.com"]}' \
		>"${output_path}"
	;;
*)
	echo "Unexpected Wrangler invocation: $*" >&2
	exit 1
	;;
esac
