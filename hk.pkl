amends
  "https://raw.githubusercontent.com/risu729/hk-config/v1.1.0/presets.pkl"

import
  "https://raw.githubusercontent.com/risu729/hk-config/v1.1.0/helpers.pkl"

local picked =
  helpers.pick(new Listing {
    "github-actions"
    "tombi"
    "yaml"
    "shfmt"
    "shellcheck"
    "mise"
    "typos"
    "hygiene"
  })

hooks = helpers.standardHooks(picked)
